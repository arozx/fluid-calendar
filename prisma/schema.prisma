generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AutoScheduleSettings {
  id                String   @id
  userId            String   @unique
  workDays          String   @default("[]")
  workHourStart     Int
  workHourEnd       Int
  selectedCalendars String   @default("[]")
  bufferMinutes     Int      @default(15)
  highEnergyStart   Int?
  highEnergyEnd     Int?
  mediumEnergyStart Int?
  mediumEnergyEnd   Int?
  lowEnergyStart    Int?
  lowEnergyEnd      Int?
  groupByProject    Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime
  User              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BetaSettings {
  id                           String  @id @default("default")
  maxActiveUsers               Int     @default(100)
  invitationValidDays          Int     @default(7)
  autoInviteEnabled            Boolean @default(false)
  autoInviteCount              Int     @default(10)
  autoInviteFrequency          String  @default("WEEKLY")
  referralBoostAmount          Float   @default(1.0)
  maxReferralBoost             Float   @default(10.0)
  showQueuePosition            Boolean @default(true)
  showTotalWaitlist            Boolean @default(true)
  invitationEmailTemplate      String  @default("")
  waitlistConfirmationTemplate String  @default("")
  reminderEmailTemplate        String  @default("")
}

model CalendarEvent {
  id                  String          @id
  feedId              String
  externalEventId     String?
  title               String
  description         String?
  start               DateTime
  end                 DateTime
  location            String?
  isRecurring         Boolean         @default(false)
  recurrenceRule      String?
  allDay              Boolean         @default(false)
  status              String?
  sequence            Int?
  created             DateTime?
  lastModified        DateTime?
  organizer           Json?
  attendees           Json?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime
  isMaster            Boolean         @default(false)
  masterEventId       String?
  recurringEventId    String?
  CalendarFeed        CalendarFeed    @relation(fields: [feedId], references: [id], onDelete: Cascade)
  CalendarEvent       CalendarEvent?  @relation("CalendarEventToCalendarEvent", fields: [masterEventId], references: [id], onDelete: Cascade)
  other_CalendarEvent CalendarEvent[] @relation("CalendarEventToCalendarEvent")

  @@index([externalEventId])
  @@index([feedId])
  @@index([masterEventId])
  @@index([recurringEventId])
  @@index([start, end])
}

model CalendarFeed {
  id                String            @id
  name              String
  url               String?
  type              String
  color             String?
  enabled           Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime
  lastSync          DateTime?
  syncToken         String?
  error             String?
  channelId         String?
  resourceId        String?
  channelExpiration DateTime?
  userId            String?
  accountId         String?
  caldavPath        String?
  ctag              String?
  CalendarEvent     CalendarEvent[]
  ConnectedAccount  ConnectedAccount? @relation(fields: [accountId], references: [id])
  User              User?             @relation(fields: [userId], references: [id])

  @@index([accountId])
}

model CalendarSettings {
  id                  String   @id
  userId              String   @unique
  defaultCalendarId   String?
  workingHoursEnabled Boolean  @default(true)
  workingHoursStart   String   @default("09:00")
  workingHoursEnd     String   @default("17:00")
  workingHoursDays    String   @default("[1,2,3,4,5]")
  defaultDuration     Int      @default(60)
  defaultColor        String   @default("#3b82f6")
  defaultReminder     Int      @default(30)
  refreshInterval     Int      @default(5)
  createdAt           DateTime @default(now())
  updatedAt           DateTime
  User                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ConnectedAccount {
  id             String         @id
  provider       String
  email          String
  accessToken    String
  refreshToken   String?
  expiresAt      DateTime
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  caldavUrl      String?
  caldavUsername String?
  userId         String?
  CalendarFeed   CalendarFeed[]
  User           User?          @relation(fields: [userId], references: [id])
  TaskProvider   TaskProvider[]

  @@unique([userId, provider, email])
  @@index([userId])
}

model DataSettings {
  id             String   @id
  userId         String   @unique
  autoBackup     Boolean  @default(true)
  backupInterval Int      @default(7)
  retainDataFor  Int      @default(365)
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  User           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model IntegrationSettings {
  id                      String   @id
  userId                  String   @unique
  googleCalendarEnabled   Boolean  @default(true)
  googleCalendarAutoSync  Boolean  @default(true)
  googleCalendarInterval  Int      @default(5)
  outlookCalendarEnabled  Boolean  @default(true)
  outlookCalendarAutoSync Boolean  @default(true)
  outlookCalendarInterval Int      @default(5)
  createdAt               DateTime @default(now())
  updatedAt               DateTime
  User                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model JobRecord {
  id          String    @id
  queueName   String
  jobId       String
  name        String
  data        Json
  status      JobStatus @default(PENDING)
  result      Json?
  error       String?
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  startedAt   DateTime?
  finishedAt  DateTime?
  userId      String?
  User        User?     @relation(fields: [userId], references: [id])

  @@unique([queueName, jobId])
  @@index([createdAt])
  @@index([queueName])
  @@index([status])
  @@index([userId])
}

model Log {
  id        String   @id
  timestamp DateTime @default(now())
  level     String
  message   String
  metadata  Json?
  source    String?
  expiresAt DateTime

  @@index([expiresAt])
  @@index([source, level])
  @@index([timestamp, level])
}

model NotificationSettings {
  id                    String   @id
  userId                String   @unique
  emailNotifications    Boolean  @default(true)
  eventInvites          Boolean  @default(true)
  eventUpdates          Boolean  @default(true)
  eventCancellations    Boolean  @default(true)
  eventReminders        Boolean  @default(true)
  defaultReminderTiming String   @default("[30]")
  createdAt             DateTime @default(now())
  updatedAt             DateTime
  dailyEmailEnabled     Boolean  @default(true)
  User                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordReset {
  id        String    @id
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model PendingWaitlist {
  id                   String   @id
  email                String   @unique
  name                 String?
  referralCode         String?
  verificationToken    String   @unique
  verificationExpiry   DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime
  interestedInLifetime Boolean  @default(false)

  @@index([email])
  @@index([verificationToken])
}

model Project {
  id              String            @id
  name            String
  description     String?
  color           String?
  status          String            @default("active")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  userId          String?
  externalId      String?
  externalSource  String?
  lastSyncedAt    DateTime?
  User            User?             @relation(fields: [userId], references: [id])
  Task            Task[]
  TaskListMapping TaskListMapping[]

  @@index([externalId, externalSource])
  @@index([status])
  @@index([userId])
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                    String             @id
  userId                String             @unique
  plan                  SubscriptionPlan   @default(FREE)
  status                SubscriptionStatus @default(ACTIVE)
  stripeCustomerId      String?            @unique
  stripePaymentIntentId String?            @unique
  amount                Int?
  discountApplied       Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime
  User                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([stripePaymentIntentId])
}

model SystemSettings {
  id                  String   @id
  googleClientId      String?
  googleClientSecret  String?
  outlookClientId     String?
  outlookClientSecret String?
  outlookTenantId     String?
  logLevel            String   @default("none")
  createdAt           DateTime @default(now())
  updatedAt           DateTime
  logDestination      String   @default("db")
  logRetention        Json?
  publicSignup        Boolean  @default(false)
  disableHomepage     Boolean  @default(false)
  resendApiKey        String?
}

model Tag {
  id     String  @id
  name   String
  color  String?
  userId String?
  User   User?   @relation(fields: [userId], references: [id])
  Task   Task[]

  @@unique([name, userId])
  @@index([name])
  @@index([userId])
}

model Task {
  id                String       @id
  title             String
  description       String?
  status            String
  dueDate           DateTime?
  duration          Int?
  priority          String?
  energyLevel       String?
  preferredTime     String?
  isAutoScheduled   Boolean      @default(false)
  scheduleLocked    Boolean      @default(false)
  scheduledStart    DateTime?
  scheduledEnd      DateTime?
  scheduleScore     Float?
  lastScheduled     DateTime?
  isRecurring       Boolean      @default(false)
  recurrenceRule    String?
  lastCompletedDate DateTime?
  externalTaskId    String?
  source            String?
  lastSyncedAt      DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime
  projectId         String?
  postponedUntil    DateTime?
  completedAt       DateTime?
  userId            String?
  startDate         DateTime?
  externalCreatedAt DateTime?
  externalListId    String?
  externalUpdatedAt DateTime?
  skipSync          Boolean      @default(false)
  syncError         String?
  syncHash          String?
  syncStatus        String?
  Project           Project?     @relation(fields: [projectId], references: [id])
  User              User?        @relation(fields: [userId], references: [id])
  TaskChange        TaskChange[]
  Tag               Tag[]

  @@index([dueDate])
  @@index([externalListId])
  @@index([externalTaskId])
  @@index([externalTaskId, source])
  @@index([isAutoScheduled])
  @@index([isRecurring])
  @@index([postponedUntil])
  @@index([priority])
  @@index([projectId])
  @@index([scheduledStart, scheduledEnd])
  @@index([source])
  @@index([startDate])
  @@index([status])
  @@index([syncStatus])
  @@index([userId])
}

model TaskChange {
  id              String           @id
  taskId          String?
  providerId      String?
  mappingId       String?
  changeType      String
  changeData      Json?
  synced          Boolean          @default(false)
  timestamp       DateTime         @default(now())
  userId          String
  createdAt       DateTime         @default(now())
  TaskListMapping TaskListMapping? @relation(fields: [mappingId], references: [id])
  TaskProvider    TaskProvider?    @relation(fields: [providerId], references: [id])
  Task            Task?            @relation(fields: [taskId], references: [id])
  User            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([changeType])
  @@index([mappingId])
  @@index([providerId])
  @@index([synced])
  @@index([taskId])
  @@index([timestamp])
  @@index([userId])
}

model TaskListMapping {
  id               String       @id
  providerId       String
  projectId        String
  externalListId   String
  externalListName String
  direction        String       @default("incoming")
  isDefault        Boolean      @default(false)
  syncEnabled      Boolean      @default(true)
  isAutoScheduled  Boolean      @default(true)
  lastSyncedAt     DateTime?
  syncStatus       String?
  lastError        String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime
  TaskChange       TaskChange[]
  Project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  TaskProvider     TaskProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, externalListId])
  @@unique([providerId, projectId])
  @@index([externalListId])
  @@index([projectId])
  @@index([providerId])
}

model TaskProvider {
  id               String            @id
  userId           String
  type             String
  name             String
  enabled          Boolean           @default(true)
  syncEnabled      Boolean           @default(true)
  syncInterval     String            @default("hourly")
  lastSyncedAt     DateTime?
  accessToken      String?
  refreshToken     String?
  expiresAt        DateTime?
  settings         Json?
  error            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime
  accountId        String?
  defaultProjectId String?
  TaskChange       TaskChange[]
  TaskListMapping  TaskListMapping[]
  ConnectedAccount ConnectedAccount? @relation(fields: [accountId], references: [id])
  User             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([type])
  @@index([userId])
}

model User {
  id                   String                @id
  name                 String?
  email                String?               @unique
  emailVerified        DateTime?
  image                String?
  role                 String                @default("user")
  Account              Account[]
  AutoScheduleSettings AutoScheduleSettings?
  CalendarFeed         CalendarFeed[]
  CalendarSettings     CalendarSettings?
  ConnectedAccount     ConnectedAccount[]
  DataSettings         DataSettings?
  IntegrationSettings  IntegrationSettings?
  JobRecord            JobRecord[]
  NotificationSettings NotificationSettings?
  PasswordReset        PasswordReset[]
  Project              Project[]
  Session              Session[]
  Subscription         Subscription?
  Tag                  Tag[]
  Task                 Task[]
  TaskChange           TaskChange[]
  TaskProvider         TaskProvider[]
  UserSettings         UserSettings?
}

model UserSettings {
  id           String   @id
  userId       String   @unique
  theme        String   @default("system")
  defaultView  String   @default("week")
  timeZone     String
  weekStartDay String   @default("sunday")
  timeFormat   String   @default("12h")
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Waitlist {
  id                        String    @id
  email                     String    @unique
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime
  name                      String?
  invitationExpiry          DateTime?
  invitationToken           String?
  invitedAt                 DateTime?
  lastVisitedAt             DateTime?
  notes                     String?
  priorityScore             Float     @default(0)
  referralCode              String    @unique
  referralCount             Int       @default(0)
  referredBy                String?
  registeredAt              DateTime?
  status                    String    @default("WAITING")
  lastPosition              Int?
  interestedInLifetime      Boolean   @default(false)
  queueNotificationsEnabled Boolean   @default(true)

  @@index([priorityScore])
  @@index([referralCode])
  @@index([referredBy])
  @@index([status])
}

enum JobStatus {
  PENDING
  ACTIVE
  COMPLETED
  FAILED
  DELAYED
  PAUSED
}

enum SubscriptionPlan {
  FREE
  LIFETIME
}

enum SubscriptionStatus {
  ACTIVE
  PAYMENT_PENDING
  PAYMENT_FAILED
}
